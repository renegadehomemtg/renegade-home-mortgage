{
  "rewrites": [
    { "source": "/api/loan-status", "destination": "/api/loan-status" },
    { "source": "/api/get-app", "destination": "/api/get-app" },
    { "source": "/api/chat-notify", "destination": "/api/chat-notify" },
    { "source": "/api/referral", "destination": "/api/referral" },
    { "source": "/api/health", "destination": "/api/health" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
